# Databricks workspace (required for SQL warehouse access)
DATABRICKS_HOST=https://YOUR-WORKSPACE.cloud.databricks.com
DATABRICKS_TOKEN=your-personal-access-token

# SQL warehouse for facility dataset queries
DATABRICKS_WAREHOUSE_ID=your-warehouse-id

# Unity Catalog (gold/silver output — must match app.yaml)
GOLD_CATALOG=main

# Source facility table (update after adding hackathon dataset from Marketplace)
FACILITY_CATALOG=databricks_virtue_foundation_dataset_dais_2026
FACILITY_SCHEMA=virtue_foundation_dataset
FACILITY_TABLE=facilities

# Lakebase (auto-injected when attached to Databricks App)
# PGHOST=
# PGDATABASE=postgres
# PGUSER=
# PGPASSWORD=
# PGPORT=5432
# PGSSLMODE=require
